              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Orders retrieved successfully\",\n  \"data\": [\n    {\n      \"id\": 1,\n      \"status\": \"pending\",\n      \"total_amount\": 49.98,\n      \"items_count\": 2,\n      \"notes\": \"Please deliver after 5pm\",\n      \"created_at\": \"2026-01-01T12:00:00Z\",\n      \"updated_at\": \"2026-01-01T12:00:00Z\",\n      \"items\": [\n        {\n          \"id\": 1,\n          \"product_name\": \"Widget\",\n          \"quantity\": 2,\n          \"price\": 19.99,\n          \"subtotal\": 39.98\n        }\n      ],\n      \"payments\": []\n    }\n  ]\n}"

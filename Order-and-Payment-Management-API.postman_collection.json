              "name": "Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"message\": \"Order created successfully\",\n  \"data\": {\n    \"id\": 2,\n    \"status\": \"pending\",\n    \"total_amount\": 49.97,\n    \"items_count\": 3,\n    \"notes\": \"Leave package at security,\",\n    \"created_at\": \"2026-01-01T12:00:00Z\",\n    \"updated_at\": \"2026-01-01T12:00:00Z\",\n    \"items\": [\n      {\n        \"id\": 2,\n        \"product_name\": \"Widget\",\n        \"quantity\": 2,\n        \"price\": 19.99,\n        \"subtotal\": 39.98\n      },\n      {\n        \"id\": 3,\n        \"product_name\": \"Gadget\",\n        \"quantity\": 1,\n        \"price\": 9.99,\n        \"subtotal\": 9.99\n      }\n    ],\n    \"payments\": []\n  }\n}"
